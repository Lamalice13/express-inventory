<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update <%= userInfos.name %></title>
  </head>
  <body>
    <h1>Update <%= userInfos.name %></h1>
    <form action="/clients/<%= userInfos.id %>/update" method="post">
      <h3>Personal informations</h3>
      <p>Name: <%= userInfos.name %></p>
      <p>Last name: <%= userInfos.lastname %></p>

      <label for="email">Email</label>
      <input
        type="email"
        name="email"
        id="email"
        value="<%= userInfos.email %>"
      />

      <label for="phone_number">Phone</label>
      <input
        type="tel"
        name="phone_number"
        id="phone_number"
        value="<%= userInfos.phone_number %>"
      />

      <% if(locals.errors) { %>
      <p style="color: red"><%= errors[0].msg %></p>
      <% } %>

      <button type="submit">Update</button>
    </form>
    <hr />

    <form
      action="/clients/<%= userInfos.id %>/update/subscription"
      method="post"
      id="sub_field"
    >
      <h3>Subscriptions</h3>
      <p>
        Start date:
        <span><%= userInfos.start_date.toISOString().split("T")[0] %></span>
      </p>
      <p>
        End date:
        <span><%= userInfos.end_date.toISOString().split("T")[0] %></span>
      </p>

      <label for="monthly">Montly</label>
      <input type="radio" name="sub_type" id="monthly" <%= userInfos.sub_type
      === "monthly" ? "checked" : "" %> />

      <label for="quarterly">Quarterly</label>
      <input type="radio" name="sub_type" id="quarterly" <%= userInfos.sub_type
      === "quarterly" ? "checked" : "" %>/>

      <button type="submit">Update</button>
    </form>
    <hr />
    <a href="/clients">Go back to clients page</a>
  </body>
</html>
